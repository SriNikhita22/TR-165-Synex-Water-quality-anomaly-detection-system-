rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users/{userId}
    // Fields: uid (string), email (string), role (enum: ADMIN, OPERATOR, VIEWER), lastLogin (timestamp)
    //
    // Collection: auditLogs/{logId}
    // Fields: timestamp (timestamp), userId (string), action (string), details (string)
    //
    // Collection: sensors/{sensorId}/readings
    // Fields: sensorId, timestamp, metrics (ph, turbidity, tds, chlorine), location
    //
    // Collection: alerts
    // Fields: sensorId, timestamp, type, severity, message, metrics, aiAnalysis, notes, actions
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'ADMIN' || 
         (request.auth.token.email == "sg5279@srmist.edu.in" && request.auth.token.email_verified == true));
    }

    function isOperator() {
      return hasRole('OPERATOR') || isAdmin();
    }

    function isViewer() {
      return hasRole('VIEWER') || isOperator();
    }

    // Validation Functions
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['ADMIN', 'OPERATOR', 'VIEWER'];
    }

    function isValidAuditLog(data) {
      return data.timestamp is timestamp &&
             data.userId == request.auth.uid &&
             data.action is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only admins can create/update roles. Users can update their own lastLogin.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == 'VIEWER'));
      allow update: if isAuthenticated() && 
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
    }

    match /sensors/{sensorId}/readings/{readingId} {
      allow read: if isAuthenticated();
      allow create: if isOperator();
      allow update, delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isOperator();
      allow update: if isOperator(); // Allow operators to add notes/actions
      allow delete: if isAdmin();
    }
  }
}
